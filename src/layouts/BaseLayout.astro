---
const {
  title = 'Veritio',
  description = 'Protocol-first evidence support for audit trails, change provenance, and governance workflows.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #17211c;
    background: #f8faf7;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
  }

  a {
    color: inherit;
  }
</style>
