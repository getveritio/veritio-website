---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import Section from '../components/Section.astro'
import FeatureCard from '../components/FeatureCard.astro'

const cloudMailto = 'mailto:hello@getveritio.com?subject=Veritio%20Cloud'
const ossRepo = 'https://github.com/getveritio/veritio'

const icon = {
  ingest: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>`,
  keys: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="3.5"/><path d="m10 13 8-8"/><path d="m15 8 2 2"/><path d="m18 5 2 2"/></svg>`,
  storage: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v14c0 1.7 3.6 3 8 3s8-1.3 8-3V5"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/></svg>`,
  graph: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2.5"/><circle cx="19" cy="6" r="2.5"/><circle cx="12" cy="18" r="2.5"/><path d="M6.7 7.8 10.6 16M17.3 7.8 13.4 16"/></svg>`,
  drift: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l2 5 4-12 2 7h6"/></svg>`,
  exportBundle: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3"/><path d="m7 8 5-5 5 5"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>`,
  portal: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="M7 6.5h.01M10 6.5h.01"/></svg>`,
  workbench: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="2"/><circle cx="17" cy="7" r="2"/><circle cx="14" cy="17" r="2"/><path d="M9.5 9.2 12.7 15.4M15.4 8.3 14.4 15"/></svg>`,
  region: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.5 2.6 3.8 5.7 3.8 9s-1.3 6.4-3.8 9c-2.5-2.6-3.8-5.7-3.8-9S9.5 5.6 12 3Z"/></svg>`,
  forward: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h12"/><path d="m12 6 6 6-6 6"/><path d="M20 5v14"/></svg>`,
  org: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21V9a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v12"/><path d="M3 21V5a1 1 0 0 1 1-1h4M21 21V5a1 1 0 0 0-1-1h-4"/><path d="M3 21h18"/></svg>`,
}
---

<BaseLayout
  title="Veritio Cloud — Hosted evidence operations"
  description="Veritio Cloud is the optional managed service for running Veritio. It consumes the same open protocol and adds managed infrastructure and operational service for evidence workflows."
>
  <Nav />

  <section
    class="py-20 sm:py-28"
    style="background-image: linear-gradient(180deg, rgb(248 250 247 / 86%), rgb(248 250 247 / 97%)), url('/evidence-grid.svg'); background-size: cover;"
  >
    <div class="container">
      <span class="eyebrow">Veritio Cloud · Optional managed service</span>
      <h1
        class="mt-5 max-w-4xl font-semibold text-ink"
        style="font-size: var(--text-display); line-height: var(--text-display--line-height); letter-spacing: var(--text-display--letter-spacing);"
      >
        Hosted evidence operations, on your terms.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
        Veritio Cloud is the optional managed way to run Veritio. It speaks the
        same open protocol as the SDK and self-hosted server, then adds managed
        infrastructure and operational service so you can run evidence workflows
        without operating the pipeline yourself. The open-source path works on
        its own — Cloud is there when you would rather not run it.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href={cloudMailto}
          class="inline-flex items-center gap-2 rounded-full bg-evergreen px-5 py-2.5 text-sm font-semibold text-surface no-underline transition-colors hover:bg-accent-strong"
        >
          Get notified
        </a>
        <a
          href={ossRepo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-line-strong px-5 py-2.5 text-sm font-semibold text-ink no-underline transition-colors hover:border-accent hover:text-accent"
        >
          Use the open-source SDK
        </a>
      </div>
    </div>
  </section>

  <Section id="capabilities">
    <span class="eyebrow">Managed capabilities</span>
    <h2
      class="mt-4 max-w-2xl font-semibold text-ink"
      style="font-size: var(--text-headline); line-height: var(--text-headline--line-height); letter-spacing: var(--text-headline--letter-spacing);"
    >
      What the hosted service adds
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-soft">
      Cloud builds on the open packages and operates the moving parts for you,
      from ingest through storage, projection, and export.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <FeatureCard title="Managed ingest" icon={icon.ingest}>
        A hosted endpoint that accepts your evidence so you don't operate the
        pipeline.
      </FeatureCard>
      <FeatureCard title="Scoped keys" icon={icon.keys}>
        Separate tokens for ingest, read, export, and admin authority.
      </FeatureCard>
      <FeatureCard title="Managed append-only storage" icon={icon.storage}>
        Durable, immutable evidence storage operated for you.
      </FeatureCard>
      <FeatureCard title="Graph projection" icon={icon.graph}>
        Evidence is projected into a connected graph automatically.
      </FeatureCard>
      <FeatureCard title="Policy drift jobs" icon={icon.drift}>
        Background checks that surface deviations from your defined policies.
      </FeatureCard>
      <FeatureCard title="Exports" icon={icon.exportBundle}>
        Generate and deliver export bundles on demand.
      </FeatureCard>
      <FeatureCard title="Customer portals" icon={icon.portal}>
        Hosted dashboards to review and manage evidence.
      </FeatureCard>
      <FeatureCard title="Hosted Workbench & MCP" icon={icon.workbench}>
        The visual evidence graph and an MCP endpoint for AI agents, hosted.
      </FeatureCard>
      <FeatureCard title="Regional storage controls" icon={icon.region}>
        Regional hosting with operational service commitments.
      </FeatureCard>
      <FeatureCard title="Forwarding" icon={icon.forward}>
        Route evidence to external SIEM or object-storage destinations.
      </FeatureCard>
      <FeatureCard title="Org & project management" icon={icon.org}>
        Multi-tenant organizations and projects with role-based access.
      </FeatureCard>
    </div>
  </Section>

  <Section id="open-core" tone="sunken">
    <span class="eyebrow">Open core</span>
    <h2
      class="mt-4 max-w-2xl font-semibold text-ink"
      style="font-size: var(--text-headline); line-height: var(--text-headline--line-height); letter-spacing: var(--text-headline--letter-spacing);"
    >
      Open core stays open
    </h2>

    <div class="mt-8 grid gap-8 lg:grid-cols-2">
      <div>
        <h3 class="text-base font-semibold text-ink">Standalone by design</h3>
        <p class="mt-3 text-base leading-relaxed text-ink-soft">
          The open-source SDK, the self-hosted server, the local Workbench, the
          verifier, and the export format work standalone. None of them is gated
          behind Cloud. You can build and run an entire evidence workflow with
          the open packages and never touch the hosted service.
        </p>
      </div>
      <div>
        <h3 class="text-base font-semibold text-ink">Cloud consumes the protocol</h3>
        <p class="mt-3 text-base leading-relaxed text-ink-soft">
          Cloud does not redefine protocol semantics. It consumes the same open
          packages and adds managed infrastructure and operational service on
          top. Evidence produced and verified the open way reads the same whether
          you run it yourself or let Cloud operate it for you.
        </p>
      </div>
    </div>

    <div class="mt-9 flex flex-wrap gap-3">
      <a
        href={ossRepo}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-line-strong px-5 py-2.5 text-sm font-semibold text-ink no-underline transition-colors hover:border-accent hover:text-accent"
      >
        Explore the open-source repo
      </a>
      <a
        href="/examples"
        class="inline-flex items-center gap-2 rounded-full border border-line-strong px-5 py-2.5 text-sm font-semibold text-ink no-underline transition-colors hover:border-accent hover:text-accent"
      >
        See examples
      </a>
    </div>
  </Section>

  <section class="border-t border-line bg-evergreen py-16 text-surface sm:py-20">
    <div class="container">
      <h2
        class="max-w-2xl font-semibold"
        style="font-size: var(--text-headline); line-height: var(--text-headline--line-height); letter-spacing: var(--text-headline--letter-spacing);"
      >
        Want hosted Veritio?
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-surface/80">
        Pricing and plans aren't public yet. Tell us what you're building and
        we'll reach out when Veritio Cloud is ready for you.
      </p>
      <div class="mt-8">
        <a
          href={cloudMailto}
          class="inline-flex items-center gap-2 rounded-full bg-surface px-5 py-2.5 text-sm font-semibold text-evergreen no-underline transition-colors hover:bg-surface-sunken"
        >
          Get notified
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
